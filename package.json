{
  "name": "oxisentinel",
  "private": true,
  "type": "module",
  "workspaces": [
    "ui/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint \"ui/*/source/**/*.ts\"",
    "console-ui:build": "npm run build --workspace @oxisentinel/console-ui"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.2",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0"
  }
}
